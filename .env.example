# Kiwi Tequila API key — required.
# Get one at https://tequila.kiwi.com/portal/sign-up
KIWI_TEQUILA_API_KEY=your_kiwi_tequila_api_key_here

# Optional: exchangerate-api.com key. If unset, the script falls back to
# Frankfurter (https://www.frankfurter.app), which is free and key-less.
EXCHANGERATE_API_KEY=

# FX commission applied on top of the EUR-converted price (decimal, e.g. 0.015 = 1.5%).
FX_COMMISSION=0.015

# Seconds to sleep between provider calls to respect rate limits.
REQUEST_DELAY_SECONDS=1.0
