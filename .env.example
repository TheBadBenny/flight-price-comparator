# --- Flight providers ----------------------------------------------------
# At least ONE of the providers below must be configured. The script auto-
# discovers which providers to run based on which keys are present.

# Kiwi Tequila — best PoS support (partner_market + curr + locale).
# Sign up: https://tequila.kiwi.com/portal/sign-up
KIWI_TEQUILA_API_KEY=

# Amadeus Self-Service — official airline data. Test environment by default.
# Sign up: https://developers.amadeus.com/register
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
# Set to "true" once you have a production app and want to hit api.amadeus.com.
AMADEUS_USE_PRODUCTION=false

# Skyscanner via RapidAPI. The host must match the Skyscanner endpoint you
# subscribed to on RapidAPI; the default below is one of the popular ones.
# Marketplace: https://rapidapi.com/search/skyscanner
RAPIDAPI_KEY=
SKYSCANNER_RAPIDAPI_HOST=skyscanner80.p.rapidapi.com

# SerpAPI Google Flights — scrapes Google Flights, supports gl + currency.
# Sign up: https://serpapi.com/users/sign_up
SERPAPI_API_KEY=

# --- FX rates ------------------------------------------------------------
# Optional: exchangerate-api.com key. If unset, the script falls back to
# Frankfurter (https://www.frankfurter.app), which is free and key-less.
EXCHANGERATE_API_KEY=

# --- Tuning --------------------------------------------------------------
# FX commission applied on top of the EUR-converted price (decimal, e.g. 0.015 = 1.5%).
FX_COMMISSION=0.015

# Seconds to sleep between provider calls to respect rate limits.
REQUEST_DELAY_SECONDS=1.0
